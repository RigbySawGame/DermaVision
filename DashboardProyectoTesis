    <script>
        document.addEventListener('DOMContentLoaded', function() {
            
            // --- Lógica de Navegación de Pestañas (Methodology) ---
            window.openTab = function(evt, tabName) {
                let i, tabcontent, tablinks;
                // Ocultar todos los contenidos
                tabcontent = document.getElementsByClassName("tab-content");
                for (i = 0; i < tabcontent.length; i++) {
                    tabcontent[i].classList.remove("active");
                }
                // Quitar estilo activo de los botones
                tablinks = document.getElementsByClassName("tab-btn");
                for (i = 0; i < tablinks.length; i++) {
                    tablinks[i].classList.remove("active");
                }
                // Mostrar actual y poner botón activo
                document.getElementById(tabName).classList.add("active");
                evt.currentTarget.classList.add("active");
            };

            // --- Configuración Global Común para Chart.js ---
            Chart.defaults.font.family = "'Inter', sans-serif";
            Chart.defaults.color = '#64748b'; // slate-500
            
            const commonOptions = {
                responsive: true,
                maintainAspectRatio: false, // CRÍTICO: Permite que el contenedor div dicte la altura
                plugins: {
                    legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20 } },
                    tooltip: {
                        backgroundColor: 'rgba(15, 23, 42, 0.9)', // slate-900
                        padding: 12,
                        cornerRadius: 8,
                        titleFont: { size: 13 },
                        bodyFont: { size: 13 }
                    }
                }
            };

            // --- Gráfico 1: Variable SUS (Bar Chart) ---
            const ctxSus = document.getElementById('susChart').getContext('2d');
            new Chart(ctxSus, {
                type: 'bar',
                data: {
                    labels: ['Promedio Industria', 'Mínimo Aceptable', 'Objetivo Tesis'],
                    datasets: [{
                        label: 'Puntaje SUS (0-100)',
                        data: [68, 70, 85], // Datos simulados para ilustrar el objetivo de la variable
                        backgroundColor: [
                            'rgba(148, 163, 184, 0.6)', // slate
                            'rgba(244, 63, 94, 0.6)',   // rose
                            'rgba(20, 184, 166, 0.8)'   // teal (brand)
                        ],
                        borderColor: [
                            'rgb(148, 163, 184)',
                            'rgb(244, 63, 94)',
                            'rgb(20, 184, 166)'
                        ],
                        borderWidth: 1,
                        borderRadius: 4
                    }]
                },
                options: {
                    ...commonOptions,
                    scales: {
                        y: { 
                            beginAtZero: true, 
                            max: 100,
                            grid: { color: 'rgba(226, 232, 240, 0.5)' }
                        },
                        x: { grid: { display: false } }
                    }
                }
            });

            // --- Gráfico 2: Variable Satisfacción (Doughnut Chart) ---
            // Representa la distribución esperada en la escala Likert (1-5)
            const ctxSat = document.getElementById('satChart').getContext('2d');
            new Chart(ctxSat, {
                type: 'doughnut',
                data: {
                    labels: ['Muy Insat. (1)', 'Insatisfecho (2)', 'Neutral (3)', 'Satisfecho (4)', 'Muy Satisfecho (5)'],
                    datasets: [{
                        data: [2, 3, 15, 45, 35], // Distribución porcentual esperada
                        backgroundColor: [
